{"actor":"Aaron Lippold","comment":null,"created_at":"2026-03-03T19:57:17Z","event_type":"claimed","id":72,"issue_id":"gh-action-security-audit-5vc","new_value":"{\"assignee\":\"Aaron Lippold\",\"status\":\"in_progress\"}","old_value":"{\"id\":\"gh-action-security-audit-5vc\",\"title\":\"Fix fork ref detection — add github.head_ref and head.repo.full_name\",\"description\":\"Line 285: Pattern only matches pull_request.head.(sha|ref). Misses github.head_ref (equivalent in PRT context) and pull_request.head.repo.full_name (used with actions/checkout repository: param). These are common dangerous checkout patterns classified as low-risk. Add to the regex.\",\"status\":\"open\",\"priority\":0,\"issue_type\":\"bug\",\"created_at\":\"2026-03-03T23:57:14Z\",\"created_by\":\"alippold\",\"updated_at\":\"2026-03-03T23:57:14Z\"}"}
