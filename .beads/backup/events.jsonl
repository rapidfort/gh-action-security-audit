{"actor":"Aaron Lippold","comment":null,"created_at":"2026-03-03T20:32:36Z","event_type":"status_changed","id":79,"issue_id":"gh-action-security-audit-das","new_value":"{\"status\":\"in_progress\"}","old_value":"{\"id\":\"gh-action-security-audit-das\",\"title\":\"Add python3 preflight check\",\"description\":\"Lines 160-168: Preflight checks verify gh CLI but not python3, which is a listed dependency. If python3 is missing, Phase 4 silently produces 'unknown' for all org settings. Add command -v python3 check alongside the gh check. (Or better: eliminate python3 dependency by using gh api --jq — see related DRY issue.)\",\"status\":\"open\",\"priority\":1,\"issue_type\":\"bug\",\"created_at\":\"2026-03-03T23:55:21Z\",\"created_by\":\"alippold\",\"updated_at\":\"2026-03-03T23:55:21Z\"}"}
